<?xml version='1.0' ?>

<launch>
  <arg name="use_sim_time" default="false"/>
  <arg name="failover_mode" default="false"/>
  <!-- <arg name="server_uri" default="http://localhost:8000/_internal"/> -->

  <!-- Common RMF nodes: building_map_server, traffic_schedule, RViz, dispatcher -->
  <include file="$(find-pkg-share rmf_demos)/common.launch.xml">
    <arg name="use_sim_time" value="$(var use_sim_time)"/>
    <arg name="viz_config_file" value="$(find-pkg-share rmf_demos)/include/warehouse_starter/warehouse_starter.rviz"/>
    <arg name="config_file" value="$(find-pkg-share rmf_demos_maps)/warehouse_starter/warehouse_starter.building.yaml"/>
    <!-- <arg name="server_uri" value="$(var server_uri)"/> -->
  </include>

  <!-- warehouseRobot fleet adapter + fleet manager -->
  <group>
    <include file="$(find-pkg-share rmf_demos_fleet_adapter)/launch/fleet_adapter.launch.xml">
      <arg name="use_sim_time" value="$(var use_sim_time)"/>
      <arg name="nav_graph_file" value="$(find-pkg-share rmf_demos_maps)/maps/warehouse_starter/nav_graphs/0.yaml"/>
      <arg name="config_file" value="$(find-pkg-share rmf_demos)/config/warehouse_starter/warehouseRobot_config.yaml"/>
    </include>
  </group>

</launch>
