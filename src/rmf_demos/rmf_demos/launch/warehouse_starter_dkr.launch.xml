<?xml version='1.0' ?>
<!--
  warehouse_starter DKR modu launch dosyası.

  Normal warehouse_starter.launch.xml'den farklar:
    1. rmf_traffic_blockade başlatılMAZ (DKR kendi enforcement'ını yapar)
    2. rmf_traffic_schedule KALIR (fleet adapter path planning ve bidding için gerekli)
    3. mutex_group_supervisor kaldırıldı (DKR kendi mutex'ini yönetir)

  Karşılaştırma mantığı:
    - RMF modu: schedule planlar + negotiation çözer + blockade enforce eder
    - DKR modu: schedule planlar (sadece), DKR resource reservation ile enforce eder
    - Gerçek trafik kontrolü farkı: negotiation+blockade vs resource reservation+deadlock detection

  Kullanım:
    ros2 launch rmf_demos warehouse_starter_dkr.launch.xml
-->

<launch>
  <arg name="use_sim_time" default="true"/>
  <arg name="headless" default="false"/>
  <arg name="viz_config_file" default="$(find-pkg-share rmf_demos)/include/warehouse_starter/warehouse_starter.rviz"/>
  <arg name="config_file" default="$(find-pkg-share rmf_demos_maps)/warehouse_starter/warehouse_starter.building.yaml"/>
  <arg name="bidding_time_window" default="2.0"/>
  <arg name="use_unique_hex_string_with_task_id" default="true"/>

  <!-- Traffic Schedule (fleet adapter path planning için GEREKLİ) -->
  <node pkg="rmf_traffic_ros2" exec="rmf_traffic_schedule" output="both" name="rmf_traffic_schedule_primary">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <!--
    rmf_traffic_blockade burada YOK — DKR kendi resource reservation
    mekanizmasıyla trafik kontrolü yapar.
    mutex_group_supervisor da yok — DKR handles this.
  -->

  <!-- Building Map Server -->
  <group>
    <node pkg="rmf_building_map_tools" exec="building_map_server" args="$(var config_file)">
      <param name="use_sim_time" value="$(var use_sim_time)"/>
    </node>
  </group>

  <!-- Visualizer (RViz) -->
  <group>
    <include file="$(find-pkg-share rmf_visualization)/visualization.launch.xml">
      <arg name="use_sim_time" value="$(var use_sim_time)"/>
      <arg name="map_name" value="L1"/>
      <arg name="viz_config_file" value="$(var viz_config_file)"/>
      <arg name="headless" value="$(var headless)"/>
    </include>
  </group>

  <!-- Door Supervisor -->
  <group>
    <node pkg="rmf_fleet_adapter" exec="door_supervisor">
      <param name="use_sim_time" value="$(var use_sim_time)"/>
    </node>
  </group>

  <!-- Lift Supervisor -->
  <group>
    <node pkg="rmf_fleet_adapter" exec="lift_supervisor">
      <param name="use_sim_time" value="$(var use_sim_time)"/>
    </node>
  </group>

  <!-- Task Dispatcher -->
  <group>
    <node pkg="rmf_task_ros2" exec="rmf_task_dispatcher" output="screen">
      <param name="use_sim_time" value="$(var use_sim_time)"/>
      <param name="bidding_time_window" value="$(var bidding_time_window)"/>
      <param name="use_unique_hex_string_with_task_id" value="$(var use_unique_hex_string_with_task_id)"/>
    </node>
  </group>

  <!-- Fleet Adapter + Fleet Manager (PathRequest remap → robot_path_requests_raw) -->
  <group>
    <include file="$(find-pkg-share rmf_demos_fleet_adapter)/launch/fleet_adapter_dkr.launch.xml">
      <arg name="use_sim_time" value="$(var use_sim_time)"/>
      <arg name="nav_graph_file" value="$(find-pkg-share rmf_demos_maps)/maps/warehouse_starter/nav_graphs/0.yaml"/>
      <arg name="config_file" value="$(find-pkg-share rmf_demos)/config/warehouse_starter/warehouseRobot_config.yaml"/>
    </include>
  </group>

</launch>
